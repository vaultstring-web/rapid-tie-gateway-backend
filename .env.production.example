# .env.production.example - Copy to .env.production and fill in real values
# This file is committed to git as a template - NEVER commit .env.production!

# ======================
# Server Configuration
# ======================
NODE_ENV=production
PORT=3001
API_PREFIX=/api

# ======================
# Database Configuration
# ======================
# PostgreSQL (for Docker, use 'postgres' as host, not 'localhost')
DATABASE_URL="postgresql://postgres:your_secure_postgres_password@postgres:5432/rapid_tie_db"

# ======================
# Redis Configuration
# ======================
# For Docker, use 'redis' as host
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_secure_redis_password
REDIS_URL=redis://:your_secure_redis_password@redis:6379

# For local development, use:
# REDIS_HOST=localhost
# REDIS_URL=redis://localhost:6379

# ======================
# JWT & Encryption
# ======================
# Generate with: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Generate with: openssl rand -hex 16
ENCRYPTION_KEY=your_encryption_key_here

# ======================
# Payment Providers
# ======================
AIRTEL_API_KEY=your-airtel-api-key
AIRTEL_API_SECRET=your-airtel-secret
AIRTEL_ENVIRONMENT=sandbox

MPAMBA_API_KEY=your-mpamba-api-key
MPAMBA_API_SECRET=your-mpamba-secret
MPAMBA_ENVIRONMENT=sandbox

# ======================
# Email Configuration
# ======================
SEND_REAL_EMAIL=true
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@domain.com
SMTP_PASS=your_smtp_password
SMTP_FROM_EMAIL=noreply@yourdomain.com
APP_NAME=RapidTie

# ======================
# Frontend URL
# ======================
FRONTEND_URL=http://localhost:3000
# For production: FRONTEND_URL=https://yourdomain.com

# ======================
# SMS Configuration
# ======================
SMS_PROVIDER=clickatell
SMS_API_KEY=your-sms-api-key

# ======================
# Rate Limiting
# ======================
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# ======================
# Logging Configuration
# ======================
# debug, info, warn, error
LOG_LEVEL=info

# ======================
# Card Payments (Stripe)
# ======================
CARD_PAYMENTS_ENABLED=false
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ======================
# Slack Alerting
# ======================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# ======================
# Security Notes
# ======================
# 1. Generate secure secrets:
#    - JWT_SECRET: openssl rand -base64 32
#    - ENCRYPTION_KEY: openssl rand -hex 16
#    - REDIS_PASSWORD: openssl rand -base64 24
#    - POSTGRES_PASSWORD: openssl rand -base64 24
