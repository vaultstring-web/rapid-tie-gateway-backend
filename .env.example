# Server Configuration
NODE_ENV=development
PORT=3001
API_PREFIX=/api

# Database
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/rapid_tie_db"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_URL=redis://:your_redis_password@localhost:6379

# JWT - Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret
JWT_REFRESH_SECRET=your_refresh_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption - Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ENCRYPTION_KEY=your_encryption_key

# Payment Providers
AIRTEL_API_KEY=your-airtel-api-key
AIRTEL_API_SECRET=your-airtel-secret
AIRTEL_ENVIRONMENT=sandbox

MPAMBA_API_KEY=your-mpamba-api-key
MPAMBA_API_SECRET=your-mpamba-secret
MPAMBA_ENVIRONMENT=sandbox

# Email
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@domain.com
SMTP_PASS=your_smtp_password
SMTP_FROM_EMAIL=noreply@yourdomain.com
APP_NAME=RapidTie

# Frontend URL
FRONTEND_URL=http://localhost:3000

# SMS
SMS_PROVIDER=clickatell
SMS_API_KEY=your-sms-api-key

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=debug

